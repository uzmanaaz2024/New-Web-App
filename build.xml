<project name="SampleWebApp" default="compile" basedir=".">

    <!-- directories -->
    <property name="src.dir" value="src"/>
    <property name="build.dir" value="build"/>
    <property name="dist.dir" value="dist"/>

    <!-- clean -->
    <target name="clean">
        <delete dir="${build.dir}"/>
        <delete dir="${dist.dir}"/>
    </target>

    <!-- create directories -->
    <target name="init">
        <mkdir dir="${build.dir}"/>
        <mkdir dir="${dist.dir}"/>
    </target>

    <!-- compile java -->
    <target name="compile" depends="init">
        <javac srcdir="${src.dir}" destdir="${build.dir}"/>
    </target>

    <!-- create jar -->
    <target name="jar" depends="compile">
        <jar destfile="${dist.dir}/SampleWebApp.jar" basedir="${build.dir}"/>
    </target>

</project>
